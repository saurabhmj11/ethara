# Backend env config
# Copy to .env and edit values

# Database - SQLite for local dev (no setup required)
# For PostgreSQL, set: postgresql+psycopg2://user:pass@localhost:5432/ethara
DATABASE_URL=sqlite:///./ethara.db

# Seed data sizes
SEED_EMPLOYEES=5000
SEED_PROJECTS=60
SEED_FLOORS=4
SEED_BAYS_PER_FLOOR=8

# AI assistant (optional - falls back to CLI auto-discovery)
ZAI_API_KEY=
